# ============================================================
#  .gitignore — General Purpose
# ============================================================

# ── OS Artifacts ────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ── Editors & IDEs ──────────────────────────────────────────
# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
Session.vim

# Sublime Text
*.sublime-workspace

# ── Node.js ─────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm/
.yarn/
dist/
build/
.cache/
.parcel-cache/
.next/
.nuxt/
out/

# Env files
.env
.env.*
!.env.example

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg
.installed.cfg
MANIFEST
.venv/
venv/
ENV/
env/
.tox/
.mypy_cache/
.dmypy.json
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# ── Logs & Temp ─────────────────────────────────────────────
logs/
*.log
*.tmp
*.temp
*.bak
*.orig

# ── Secrets & Credentials ───────────────────────────────────
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ── Build / Compiled Output ─────────────────────────────────
*.o
*.a
*.so
*.dll
*.exe
*.out
*.class
*.jar

# ── Archives ────────────────────────────────────────────────
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
